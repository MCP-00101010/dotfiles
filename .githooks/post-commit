#!/usr/bin/env sh
set -eu

if [ "${MORPHEUS_CHANGELOG_UPDATING:-}" = "1" ]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"

if command -v python >/dev/null 2>&1; then
  python "$repo_root/scripts/update_changelog.py"
elif command -v python3 >/dev/null 2>&1; then
  python3 "$repo_root/scripts/update_changelog.py"
elif command -v py >/dev/null 2>&1; then
  py -3 "$repo_root/scripts/update_changelog.py"
else
  exit 0
fi

if ! git diff --quiet -- CHANGELOG.md; then
  git add CHANGELOG.md
  MORPHEUS_CHANGELOG_UPDATING=1 git commit --amend --no-edit --no-verify >/dev/null 2>&1
fi
