# common git aliases

alias gst="git status -sb"
alias ga="git add"
alias gaa="git add -A"
alias gc="git commit"
alias gca="git commit --amend"
alias gco="git checkout"
alias gb="git branch"
alias gd="git diff"
alias gl="git log --oneline --graph --decorate -20"
alias gpl="git pull"
alias gps="git push"
